{
  "name": "next-queue-firebase-priority",
  "version": "1.0.0",
  "description": "LGU Queuing System with Firebase priority queue",
  "author": "LGU Queuing System",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "dev:local": "next dev",
    "build": "next build",
    "start": "next start",
    "electron": "electron .",
    "electron:dev": "concurrently -k \"npm:dev:local\" \"wait-on tcp:3000 && npm run electron\"",
    "electron:kiosk": "cross-env ELECTRON_KIOSK=1 electron .",
    "dist:electron": "next build && electron-builder",
    "dist:win": "next build && electron-builder --win",
    "dist:mac": "next build && electron-builder --mac",
    "dist:linux": "next build && electron-builder --linux"
  },
  "dependencies": {
    "firebase": "^11.4.0",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.lgu.queuingsystem",
    "productName": "Queuing System",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      ".next/**/*",
      "public/**/*",
      "package.json",
      "node_modules/**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,*.test.js,*.spec.js}",
      "!**/node_modules/.cache",
      "!**/{.DS_Store,.git,.idea,.vscode}"
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": ".env"
      }
    ],
    "asar": false,
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Queuing System"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "category": "public.app-category.business"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] }
      ],
      "category": "Office"
    }
  }
}
