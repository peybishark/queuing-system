FIREBASE_API_KEY=your_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# Optional: custom city hall / LGU name for display header
QUEUE_ORG_NAME=LGU Queuing System

# Printing — auto print without dialog (default: true)
# Set to "false" if you want the print dialog to appear instead.
SILENT_PRINT=true

# Optional: specific printer name (e.g., "EPSON TM-T82"). Leave blank to use system default printer.
PRINTER_NAME=
